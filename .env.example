APP_NAME=AI Chatbot API
APP_VERSION=1.0.0
DEBUG=True

# Github API 
GITHUB_TOKEN=
GITHUB_MODEL_ENDPOINT=
GITHUB_MODEL_NAME=

# Generation
MAX_TOKENS=1000
TEMPERATURE=0.7
TOP_P=1.0

# Persona
BOT_NAME=Aria
BOT_PERSONA=a helpful, friendly AI assistant for software developers
BOT_LANGUAGE_STYLE=clear, concise, and professional
MAX_RESPONSE_LENGTH=3-5 sentences unless more detail is needed

# Memory
DATABASE_URL=data/chatbot.db
MAX_HISTORY_MESSAGES=10
MAX_HISTORY_TOKENS=3000

# Security — change API_SECRET_KEY to something strong
API_SECRET_KEY=my-super-secret-key-change-this
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
MAX_MESSAGE_LENGTH=2000